FROM registry.redhat.io/ubi9/python-311:latest

WORKDIR /opt/app-root/src

# Install dependencies (includes all memoryhub_core requirements from pyproject.toml)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Download spaCy model at build time (12MB, air-gap safe)
RUN python -m spacy download en_core_web_sm

# Copy memoryhub_core library (Python modules only, not pip-installable)
COPY memoryhub_core/ ./memoryhub_core/

# Copy MCP server application code
COPY src/ ./src/
COPY conftest.py ./

# Fix permissions for OpenShift arbitrary UIDs
RUN find . -type f -name "*.py" -exec chmod 644 {} \; && \
    find . -type d -exec chmod 755 {} \;

# Set environment for HTTP transport
ENV MCP_TRANSPORT=http \
    MCP_HTTP_HOST=0.0.0.0 \
    MCP_HTTP_PORT=8080 \
    MCP_HTTP_PATH=/mcp/

USER 1001

# Use FastMCP 3 entry point
CMD ["python", "-m", "src.main"]
